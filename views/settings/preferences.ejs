<div class="tab-pane fade" id="preferences" role="tabpanel" aria-labelledby="preferences" tabindex="0">
  <div class="row">
    <div class="col-12 col-md-8">
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between">
          <h5><i class="bi bi-palette"></i> Theme Selector</h5>
          
          <div id="themeSpinner" class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
        <div class="card-body">
          <div class="row g-2">
            <% const themes = [
              { value: 'primary', label: 'Primary', class: 'alert-primary' },
              { value: 'secondary', label: 'Secondary', class: 'alert-secondary' },
              { value: 'success', label: 'Success', class: 'alert-success' },
              { value: 'danger', label: 'Danger', class: 'alert-danger' },
              { value: 'warning', label: 'Warning', class: 'alert-warning' },
              { value: 'info', label: 'Info', class: 'alert-info' },
              { value: 'dark', label: 'Dark', class: 'alert-dark text-white bg-dark' },
              { value: 'light', label: 'Light', class: 'alert-light', border: true }
            ]; %>
            
            <% themes.forEach(theme => { %>
              <div class="col-6 col-md-3">
                <div class="theme-option" data-theme="<%= theme.value %>" style="cursor: pointer;" >
                  <div class="alert <%= theme.class %> mb-1 p-2">
                    <%= theme.label %>
                    <% if (user.preferences?.theme === theme.value) { %>
                      <i class="bi bi-check2"></i>
                      <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
   
          </div>
        </div>
      </div>

    </div> <!-- closes col-12 col-md-8 -->
  </div> <!-- closes row -->
</div> <!-- closes tab-pane -->

<style>
  .theme-option {
    transition: transform 0.2s, opacity 0.2s;
  }
  .theme-option:hover {
    transform: scale(1.02);
    opacity: 0.9;
  }
  .theme-option.active {
    outline: 2px solid #0d6efd;
    outline-offset: 2px;
    border-radius: 6px;
  }
</style>

<script src="/js/alert.js"></script>
<script>
  let currentTheme = null
  const themeSpinner = document.getElementById("themeSpinner")
  themeSpinner.style.display = 'none'

  function applyTheme(theme) {
    document.body.classList.remove('theme-primary', 'theme-secondary', 'theme-success', 'theme-danger', 'theme-warning', 'theme-info', 'theme-dark', 'theme-light')
    document.body.classList.add(`theme-${theme}`)
    
    document.querySelectorAll('.theme-option').forEach(option => {
      if (option.dataset.theme === theme) {
        option.classList.add('active')
      } else {
        option.classList.remove('active')
      }
    })
    currentTheme = theme
  }
  
  // Add click handlers
  document.querySelectorAll('.theme-option').forEach(option => {
    option.addEventListener('click', async () => {
      const theme = option.dataset.theme
      applyTheme(theme)
      themeSpinner.style.display = 'inline-block'
      
      try {
        const response = await api({
          url: '/v1/settings/change-theme',
          method: 'PATCH', 
          data: { theme: theme }
        })

        if (response.success) {
          showAlert('success', response.message)

          setTimeout(() => {
            window.location.reload()
          }, 1000)
        }
      } catch (err) {
        showAlert('danger', err.response.data.message)
      } finally {
        themeSpinner.style.display = 'none'
      }
    })
  })
  
  applyTheme(currentTheme)
</script>