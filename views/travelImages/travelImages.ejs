<div class="p-2 p-lg-4 my-2" id="travelImagesSection">
  <!-- Header Section -->
  <div class="d-flex justify-content-between justify-content-md-start align-items-center gap-3">
    <h3>
      <a class="text-black" style="text-decoration: none;" data-bs-toggle="collapse" role="button" href="#travelImagesCollapse" aria-expanded="true" aria-controls="travelImagesCollapse">
        <i class="bi bi-caret-down-fill" id="travelImagesCollapseIcon"></i>
      </a>
      Travel Images (<%- travelImages.length %>)
      <% if (user.cacheToggles.travelImages) { %>
        <span class="badge bg-warning text-dark fs-6 py-1 px-2">Cache Active</span>
      <% } %>
    </h3>
    <% if (user.role === 'admin') { %>
      <a href="travel-images/add">
        <h5><i class="bi bi-plus-circle-fill"></i></h5>
      </a>
    <% } %>
  </div>

  <% if (travelImages.length === 0) { %>
    <div class="alert alert-light w-25" role="alert">
      There are no Travel Images yet!
    </div>
  <% } else { %>
    
    <div class="container-fluid show" id="travelImagesCollapse">
      <!-- Country Filter -->
      <div class="col-md-3 mb-3">
        <label class="form-label fw-semibold small text-muted mb-1">
          <i class="bi bi-geo-alt me-1"></i> Filter by Country
        </label>
        <select class="form-select" id="countryFilter">
          <option value="all" <%= currentCountry === 'all' ? 'selected' : '' %>>🌍 All Countries</option>
          <option value="Lebanon" <%= currentCountry === 'Lebanon' ? 'selected' : '' %>>🇱🇧 Lebanon</option>
          <option value="Syria" <%= currentCountry === 'Syria' ? 'selected' : '' %>>🇸🇾 Syria</option>
          <option value="Armenia" <%= currentCountry === 'Armenia' ? 'selected' : '' %>>🇦🇲 Armenia</option>
          <option value="UAE" <%= currentCountry === 'UAE' ? 'selected' : '' %>>🇦🇪 United Arab Emirates</option>
        </select>
      </div>

      <!-- Images Grid -->
      <div 
        id="<%= user.role === 'admin' ? 'admin-trave-images-container' : 'travel-images-container' %>"
        class="row row-cols-2 row-cols-sm-4 row-cols-md-6 g-4"
      >
        <% travelImages.forEach(image => { %>
          
          <%- include('./travelImage', { image }) %>
          <%- include('../partials/_deleteModal', { 
            data: { 
              id: image._id, 
              deleteId: "travelImageDeleteBtn",
              publicId: image.public_id.slice(8, image.public_id.length) 
            }, 
            type: 'Travel Image' 
          }) %>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<script>
  document.getElementById('countryFilter').addEventListener('change', (e) => {
    const country = e.target.value
    const currentStatus = '<%= currentStatus %>'
    window.location.href = `/cms?status=${currentStatus}&country=${country}#travelImagesSection`
  })

  const deleteTravelImagesBtn = document.querySelectorAll("#travelImageDeleteBtn")
  const travelImagesCollapse = document.getElementById('travelImagesCollapse')
  const travelImagesCollapseIcon = document.getElementById('travelImagesCollapseIcon')
  const travelImagesContainer = document.getElementById('admin-travel-images-container')

  travelImagesCollapse.addEventListener('hide.bs.collapse', () => {
    travelImagesCollapseIcon.classList.remove('bi-caret-down-fill')
    travelImagesCollapseIcon.classList.add('bi-caret-right-fill')
  })

  travelImagesCollapse.addEventListener('show.bs.collapse', () => {
    travelImagesCollapseIcon.classList.remove('bi-caret-right-fill')
    travelImagesCollapseIcon.classList.add('bi-caret-down-fill')
  })

  deleteTravelImagesBtn.forEach(btn => {
    btn.addEventListener('click', async function(e) {
      const id = btn.getAttribute("data-id")
      const publicId = btn.getAttribute("data-public-id")

      try {
        const response = await api({
          url: `v1/travel-images/${id}`,
          method: 'delete',
          data: { publicId }
        })
          showAlert('success', response.message)
          setTimeout(() => location.reload(), 1500)
        } catch (err) {
          showAlert('danger', 'An unexpected error occurred.')
        }
    })
  })
  
</script>