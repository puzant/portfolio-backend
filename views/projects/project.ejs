<div class="card shadow-sm" id="project">
  <div class="card-body">
    <div class="d-flex justify-content-between">
      <div>
        <input class="form-check-input project-checkbox" type="checkbox" value="<%= project._id %>" data-public-id="<%= project.public_id %>" id="project_<%= project._id %>">
        <b class="card-title mx-1"><%= project.name %> 
          <span class="badge <%=project.active ? 'bg-success' : 'bg-warning text-dark'%>"><%= project.active ? 'Active' : 'Inactive' %></span>
        </b>
      </div>

      <% if (userRole === 'admin') { %>
        <div class="d-flex gap-2">
          <a href="projects/edit/<%= project._id %>"><i class="bi bi-pencil"></i></a>
          <i role="button" class="bi bi-trash3 pe-auto text-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-<%= project._id %>"></i>
        </div>
      <% } %>
    </div>

    <p class="card-text text-truncate" style="width: 250px"><%= project.description %></p>
    
    <a href="<%= project.link %>" target="_blank"><i class="bi bi-link-45deg"></i> Project Link</a>
    <% if (project.repo) { %>
      | <a href="<%= project.repo %>" target="_blank"><i class="bi bi-github"></i> Github Repo</a>
    <% } %>
    <hr>
    <img src="<%= project.preview %>" style="width: 100%; height: 100px;" class="rounded object-fit-cover" alt="">
  </div>
</div>