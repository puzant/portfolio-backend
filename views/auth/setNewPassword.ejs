<!DOCTYPE html>
<html lang="en">
<%- include('../partials/_head') %>
<body class="bg-light">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
              <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-flex mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#0d6efd" class="bi bi-key" viewBox="0 0 16 16">
                  <path d="M0 8a4 4 0 0 1 7.465-2H14a.5.5 0 0 1 .354.146l1.5 1.5a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0L13 9.207l-.646.647a.5.5 0 0 1-.708 0L11 9.207l-.646.647a.5.5 0 0 1-.708 0L9 9.207l-.646.647a.5.5 0 0 1-.708 0L7 9.207l-.646.647a.5.5 0 0 1-.708 0L5 9.207l-.646.647a.5.5 0 0 1-.708 0L3 9.207l-.646.647a.5.5 0 0 1-.708 0L1 9.207l-.646.647a.5.5 0 0 1-.708 0L0 9.207V8z"/>
                </svg>
              </div>
              <h1 class="h3 fw-bold mb-2">Set New Password</h1>
              <p class="text-muted small">Create a strong password for your account</p>
            </div>

            <form id="resetPasswordForm" action="/v1/auth/set-new-password" method="POST">
              <input type="hidden" name="token" value="<%= token %>">

              <div class="mb-3">
                <label for="newPassword" class="form-label fw-semibold">New Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"   fill="#6c757d" class="bi bi-lock" viewBox="0 0 16 16">
                      <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                  </span>
                  <input type="password" class="form-control border-start-0 ps-0" id="newPassword" name="newPassword" required>
                </div>
              </div>

              <div class="mb-4">
                <label for="confirmPassword" class="form-label fw-semibold">Confirm Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" class="bi bi-check-circle" viewBox="0 0 16 16">
                      <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                      <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                    </svg>
                  </span>
                  <input type="password" class="form-control border-start-0 ps-0" id="confirmPassword" name="confirmPassword" required>
                </div>
                <div id="passwordMatchFeedback" class="form-text small"></div>
              </div>

              <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-lg me-2" viewBox="0 0 16 16">
                  <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.06.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z"/>
                </svg>
                Reset Password
              </button>
            </form>

            <div class="text-center mt-4">
              <a href="/login" class="text-decoration-none small">
                ← Back to Login
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/alert.js"></script>
  <script>
    // Simple password match validation
    const password = document.getElementById('newPassword')
    const confirm = document.getElementById('confirmPassword')
    const feedback = document.getElementById('passwordMatchFeedback')

    function validateMatch() {
      if (confirm.value === '') {
        feedback.textContent = ''
      } else if (password.value === confirm.value) {
        feedback.textContent = '✓ Passwords match'
        feedback.classList.add('text-success')
        feedback.classList.remove('text-danger')
      } else {
        feedback.textContent = '✗ Passwords do not match'
        feedback.classList.add('text-danger')
        feedback.classList.remove('text-success')
      }
    }

    password.addEventListener('input', validateMatch)
    confirm.addEventListener('input', validateMatch)
    const form = document.getElementById('resetPasswordForm')

    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      const formData = new FormData(form)

      try {
        const response = await api({
          url: this.action,
          method: this.method,
          data: Object.fromEntries(formData),
        })

        if (response.success) {
          showAlert('success', 'Password reset successful!');
        } else {
          showAlert('danger', response.message || 'Something went wrong')
        }
      } catch (err) {
        console.log(err)
        showAlert('danger', err.response?.data?.message || 'Invalid or expired reset link. Please request a new one.')
      }
    })
  </script>
</body>
</html>