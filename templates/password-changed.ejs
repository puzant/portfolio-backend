<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background-color: #4CAF50; padding: 10px; text-align: center; }
    .header h2 { color: white; margin: 0; }
    .content { padding: 20px; border: 1px solid #ddd; border-top: none; }
    .security-box { background-color: #f9f9f9; padding: 15px; margin: 20px 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h2>Password Changed Successfully</h2>
    </div>
    
    <div class="content">
      <p>Hello <strong><%= username %></strong>,</p>
      
      <p>Your password was successfully changed on 
         <strong><%= changeTime %></strong>.</p>
      
      <div class="security-box">
        <p style="margin: 0;"><strong>Security Details:</strong></p>
        <p style="margin: 5px 0 0; font-size: 14px; color: #666;">
          IP Address: <%= ipAddress %><br>
          Device: <%= userAgent %>
        </p>
      </div>
      
      <p>If you did not make this change, please contact support immediately.</p>
    </div>
  </div>
</body>
</html>